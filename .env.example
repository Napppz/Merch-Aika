# Database Connection
DATABASE_URL=your_neon_postgresql_connection_string

# JWT Secret (generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_random_32_character_hex_string

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@merch-aika.com

# Admin Email
ADMIN_EMAIL=admin@merch-aika.com

# Allowed Origins (CORS)
ALLOWED_ORIGINS=https://merch-aika.vercel.app,https://www.merch-aika.vercel.app,http://localhost:3000

# Environment
NODE_ENV=production

# Payment Settings (QRIS)
PAYMENT_PROOF_UPLOAD_PATH=./images/payment-proof
PAYMENT_TIMEOUT_MINUTES=60
