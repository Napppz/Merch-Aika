# Admin Password Configuration
# Generate hash using: node generate-admin-hash.js
# Must match the admins.password_hash value stored in Neon

# For password "Aikanap2213":
ADMIN_PASSWORD_HASH=7adcf1e2f00fc4e0bd3260bfe137d562d41d841bd7af170d7084e9e010c98670

# (Optional) Override default admin username
# Default: Aika
ADMIN_USERNAME=Aika

